@model SMARTFIX.Models.Diagnosa

@{
    ViewData["Title"] = "Detail Diagnosa";

    var detail = ViewBag.Detail as List<SMARTFIX.Models.DetailDiagnosa>;
}

<div class="card">

    <div class="card-body">

        <div class="text-center mb-4">

            <i class="bi bi-clipboard2-pulse-fill text-primary"
               style="font-size:70px;"></i>

            <h3 class="fw-bold mt-3">

                Detail Hasil Diagnosa

            </h3>

            <p class="text-muted">

                Informasi lengkap hasil diagnosa smartphone

            </p>

        </div>

        <div class="row mb-4">

            <div class="col-md-6">

                <div class="border rounded-3 p-3 h-100">

                    <h6 class="text-primary fw-bold">

                        <i class="bi bi-person-circle me-2"></i>

                        Nama User

                    </h6>

                    <p class="mb-0">

                        @Model.NamaUser

                    </p>

                </div>

            </div>

            <div class="col-md-6">

                <div class="border rounded-3 p-3 h-100">

                    <h6 class="text-success fw-bold">

                        <i class="bi bi-calendar-event me-2"></i>

                        Tanggal Diagnosa

                    </h6>

                    <p class="mb-0">

                        @Model.TanggalDiagnosa.ToString("dd MMMM yyyy HH:mm")

                    </p>

                </div>

            </div>

        </div>

        <div class="card mb-4">

            <div class="card-header bg-primary text-white">

                <i class="bi bi-list-check me-2"></i>

                Gejala yang Dipilih

            </div>

            <div class="card-body">

                <ul class="list-group list-group-flush">

                    @foreach (var item in detail)
                    {
                        <li class="list-group-item">

                            <i class="bi bi-check-circle-fill text-success me-2"></i>

                            <span class="badge bg-primary me-2">

                                @item.Gejala?.KodeGejala

                            </span>

                            @item.Gejala?.NamaGejala

                        </li>
                    }

                </ul>

            </div>

        </div>

        <div class="card mb-4">

            <div class="card-header bg-warning">

                <i class="bi bi-tools me-2"></i>

                Hasil Diagnosa

            </div>

            <div class="card-body">

                <div class="mb-3">

                    <label class="fw-bold">

                        Kode Kerusakan

                    </label>

                    <br />

                    <span class="badge bg-danger fs-6">

                        @Model.Kerusakan?.KodeKerusakan

                    </span>

                </div>

                <div class="mb-3">

                    <label class="fw-bold">

                        Nama Kerusakan

                    </label>

                    <p>

                        @Model.Kerusakan?.NamaKerusakan

                    </p>

                </div>

                <div>

                    <label class="fw-bold">

                        Solusi

                    </label>

                    <div class="alert alert-success">

                        @Model.Kerusakan?.Solusi

                    </div>

                </div>

            </div>

        </div>

        <div class="text-center">

            <a asp-action="Index"
               class="btn btn-secondary px-4">

                <i class="bi bi-arrow-left-circle me-2"></i>

                Kembali

            </a>

        </div>

    </div>

</div>