@model SMARTFIX.Models.Gejala

@{
    ViewData["Title"] = "Edit Gejala";
}

<div class="card mx-auto" style="max-width:700px;">

    <div class="card-header bg-warning">

        <h5 class="mb-0">

            <i class="bi bi-pencil-square me-2"></i>

            Edit Data Gejala

        </h5>

    </div>

    <div class="card-body">

        <form asp-action="Edit" method="post">

            <input asp-for="IdGejala" type="hidden" />

            <div class="mb-3">

                <label asp-for="KodeGejala"
                       class="form-label fw-semibold">

                    Kode Gejala

                </label>

                <input asp-for="KodeGejala"
                       class="form-control" />

                <span asp-validation-for="KodeGejala"
                      class="text-danger"></span>

            </div>

            <div class="mb-4">

                <label asp-for="NamaGejala"
                       class="form-label fw-semibold">

                    Nama Gejala

                </label>

                <input asp-for="NamaGejala"
                       class="form-control" />

                <span asp-validation-for="NamaGejala"
                      class="text-danger"></span>

            </div>

            <div class="text-end">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left"></i>

                    Kembali

                </a>

                <button type="submit"
                        class="btn btn-warning">

                    <i class="bi bi-pencil-square"></i>

                    Update

                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts{

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}