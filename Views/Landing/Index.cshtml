@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="id">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>SMARTFIX</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{

            min-height:100vh;

            background:linear-gradient(135deg,#0d6efd,#4dabf7);

            font-family:'Segoe UI',sans-serif;

            display:flex;

            justify-content:center;

            align-items:center;

        }

        .landing-card{

            width:100%;

            max-width:1100px;

            background:white;

            border-radius:25px;

            overflow:hidden;

            box-shadow:0 20px 50px rgba(0,0,0,.20);

        }

        .header{

            background:#0d6efd;

            color:white;

            text-align:center;

            padding:40px;

        }

        .header h1{

            font-weight:700;

            margin-bottom:10px;

        }

        .header p{

            margin-bottom:8px;

            font-size:18px;

        }

        .method{

            display:inline-block;

            background:white;

            color:#0d6efd;

            padding:8px 20px;

            border-radius:30px;

            font-weight:600;

            margin-top:15px;

        }

        .content{

            padding:50px;

        }

        .role-card{

            border:0;

            border-radius:20px;

            transition:.35s;

            box-shadow:0 8px 20px rgba(0,0,0,.08);

            height:100%;

        }

        .role-card:hover{

            transform:translateY(-8px);

            box-shadow:0 18px 35px rgba(0,0,0,.15);

        }

        .role-icon{

            font-size:70px;

            margin-bottom:20px;

        }

        .footer{

            text-align:center;

            padding:20px;

            color:#6c757d;

            border-top:1px solid #eee;

        }

    </style>

</head>

<body>

<div class="landing-card">

    <div class="header">

        <h1>

            <i class="bi bi-cpu-fill me-2"></i>

            SMARTFIX

        </h1>

        <p>

            Sistem Pakar Diagnosa Kerusakan Smartphone

        </p>

        <div class="method">

            Metode Forward Chaining

        </div>

    </div>

    <div class="content">

        <div class="row g-4">

                        <!-- USER -->

            <div class="col-lg-6">

                <div class="card role-card">

                    <div class="card-body text-center p-5">

                        <i class="bi bi-phone-fill text-primary role-icon"></i>

                        <h3 class="fw-bold">

                            USER

                        </h3>

                        <p class="text-muted mb-4">

                            Lakukan diagnosa kerusakan smartphone dengan memilih gejala yang dialami.

                        </p>

                        <a asp-controller="User"
                           asp-action="Diagnosa"
                           class="btn btn-primary btn-lg px-4">

                            <i class="bi bi-search me-2"></i>

                            Mulai Diagnosa

                        </a>

                    </div>

                </div>

            </div>

            <!-- ADMIN -->

            <div class="col-lg-6">

                <div class="card role-card">

                    <div class="card-body text-center p-5">

                        <i class="bi bi-person-lock text-success role-icon"></i>

                        <h3 class="fw-bold">

                            ADMINISTRATOR

                        </h3>

                        <p class="text-muted mb-4">

                            Login sebagai administrator untuk mengelola data sistem pakar SMARTFIX.

                        </p>

                        <a asp-controller="Login"
                           asp-action="Index"
                           class="btn btn-success btn-lg px-4">

                            <i class="bi bi-box-arrow-in-right me-2"></i>

                            Login Admin

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="footer">

        © @DateTime.Now.Year SMARTFIX | Sistem Pakar Diagnosa Kerusakan Smartphone

    </div>

</div>

</body>

</html>