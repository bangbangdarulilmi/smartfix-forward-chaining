<!DOCTYPE html>
<html lang="id">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - SMARTFIX</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{

            background:#f5f7fb;
            overflow-x:hidden;

        }

        /*==============================
                SIDEBAR
        ==============================*/

        .sidebar{

            position:fixed;

            top:0;

            left:0;

            width:260px;

            height:100vh;

            background:linear-gradient(180deg,#0d6efd,#0a58ca);

            color:#fff;

            z-index:1000;

            overflow-y:auto;

            box-shadow:4px 0 18px rgba(0,0,0,.15);

        }

        .logo{

            height:90px;

            display:flex;

            justify-content:center;

            align-items:center;

            font-size:26px;

            font-weight:700;

            letter-spacing:2px;

            border-bottom:1px solid rgba(255,255,255,.15);

        }

        .menu{

            padding:15px 0;

        }

        .menu a{

            display:flex;

            align-items:center;

            gap:15px;

            color:white;

            text-decoration:none;

            padding:16px 30px;

            font-size:17px;

            transition:.25s;

        }

        .menu a i{

            font-size:23px;

            width:28px;

            text-align:center;

        }

        .menu a:hover{

            background:rgba(255,255,255,.15);

            padding-left:40px;

        }

        .menu a.active{

            background:rgba(255,255,255,.18);

            border-left:5px solid #fff;

        }

        /*==============================
                CONTENT
        ==============================*/

        .content{

            margin-left:260px;

            min-height:100vh;

            background:#f5f7fb;

        }

        /*==============================
                TOPBAR
        ==============================*/

        .topbar{

            height:85px;

            background:white;

            display:flex;

            justify-content:space-between;

            align-items:center;

            padding:0 40px;

            box-shadow:0 2px 12px rgba(0,0,0,.08);

        }

        .topbar h3{

            margin:0;

            font-weight:700;

            font-size:22px;

            color:#222;

        }

        .admin-name{

            color:#0d6efd;

            font-weight:600;

        }

        /*==============================
                PAGE
        ==============================*/

        .page{

            padding:35px;

        }

        /*==============================
                CARD
        ==============================*/

        .card{

            border:none;

            border-radius:18px;

            box-shadow:0 8px 20px rgba(0,0,0,.08);

        }

        .card-body{

            padding:28px;

        }

        /*==============================
                TABLE
        ==============================*/

        .table{

            margin-bottom:0;

            font-size:15px;

        }

        .table thead th{

    background:#cfe2ff!important;

    text-align:center;

    vertical-align:middle;

    font-weight:600;

    font-size:15px;

    padding:11px;

    border:1px solid #d7dee7;

}

.table tbody td{

    padding:10px 12px;

    font-size:14px;

    vertical-align:middle;

}

        .table-hover tbody tr:hover{

            background:#f8fbff;

        }

        /*==============================
                BUTTON
        ==============================*/

        .btn{

    border-radius:10px;

    padding:8px 16px;

    font-size:14px;

}

        .btn-sm{

            padding:8px 14px;

        }

        /*==============================
                INPUT
        ==============================*/

        .form-control{

    height:42px;

    border-radius:10px;

    font-size:14px;

}

        .form-select{

            border-radius:10px;

            height:48px;

        }

        /*==============================
                MODAL
        ==============================*/

        .modal-content{

            border:none;

            border-radius:18px;

        }

        footer{

            display:none;

        }

    </style>

</head>

<body>

    <!-- SIDEBAR -->

    <div class="sidebar">

        <div class="logo">

            SMARTFIX

        </div>

        <div class="menu">

            <a asp-controller="Home" asp-action="Index">

                <i class="bi bi-speedometer2"></i>

                Dashboard

            </a>

            <a asp-controller="Gejala" asp-action="Index">

                <i class="bi bi-list-check"></i>

                Data Gejala

            </a>

            <a asp-controller="Kerusakan" asp-action="Index">

                <i class="bi bi-tools"></i>

                Data Kerusakan

            </a>

            <a asp-controller="Rule" asp-action="Index">

                <i class="bi bi-diagram-3"></i>

                Basis Pengetahuan

            </a>

            <a asp-controller="Diagnosa" asp-action="Index">

                <i class="bi bi-search"></i>

                Diagnosa

            </a>

            <a asp-controller="Riwayat" asp-action="Index">

                <i class="bi bi-clock-history"></i>

                Riwayat Diagnosa

            </a>

            <a asp-controller="Admin" asp-action="Index">

                <i class="bi bi-person"></i>

                Data Admin

            </a>

            <a asp-controller="Login"
   asp-action="Logout"
   class="dropdown-item text-danger"
   onclick="return confirm('Apakah Anda yakin ingin logout?');">

    <i class="bi bi-box-arrow-right me-2"></i>
    Logout

</a>

        </div>

    </div>

                <!-- ==============================
            CONTENT
    =============================== -->

    <div class="content">

        <!-- TOPBAR -->

        <div class="topbar">

            <h3>

                @ViewData["Title"]

            </h3>

            <div>

                Selamat Datang,

                <span class="admin-name">

                    @Context.Session.GetString("Nama")

                </span>

            </div>

        </div>

        <!-- PAGE -->

        <div class="page">

            @RenderBody()

        </div>

    </div>

    <!-- Bootstrap JS -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>